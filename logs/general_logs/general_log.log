ified conversational question. CRITICAL: Do NOT extract keywords, summarize, or truncate. Pass the exact natural language intent.', 'type': 'string'}}, 'required': ['query'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'change_directory', 'description': 'Change the current working directory to the given path.', 'parameters': {'properties': {'directory': {'description': 'Path to the directory to change into; relative or absolute', 'type': 'string'}}, 'required': ['directory'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'list_directory', 'description': 'List the names of all entries in the given directory.', 'parameters': {'properties': {'directory': {'anyOf': [{'type': 'string'}, {'type': 'null'}], 'default': None, 'description': 'Optional path. If not provided, lists the current directory.'}}, 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'get_working_directory', 'description': 'Return the absolute path of the current working directory.', 'parameters': {'properties': {}, 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'path_exists', 'description': 'Check whether a file or directory exists at the given path.', 'parameters': {'properties': {'target': {'description': 'Path to check; relative or absolute', 'type': 'string'}}, 'required': ['target'], 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'list_files_recursive', 'description': 'List all files matching the glob pattern recursively under the given directory.', 'parameters': {'properties': {'directory': {'default': '.', 'description': 'Directory to search under; defaults to the current working directory', 'type': 'string'}, 'pattern': {'default': '*', 'description': "Glob pattern to match filenames against, e.g. '*.py' or '*'", 'type': 'string'}}, 'type': 'object'}}}, {'type': 'function', 'function': {'name': 'make_directory', 'description': 'Create a directory along with any missing parent directories.', 'parameters': {'propertie